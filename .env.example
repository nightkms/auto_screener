# DART OpenAPI (https://opendart.fss.or.kr/)
DART_API_KEY=

# Telegram Bot
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# 운영 설정
SCREENER_TOP_N=5
SCREENER_TIMEZONE=Asia/Seoul
SCREENER_CRON=0 8 * * SAT
DASHBOARD_PORT=8765
CLAUDE_SUB_MODEL=claude-sonnet-4-6
CLAUDE_SYNTH_MODEL=claude-opus-4-7
LOG_LEVEL=INFO

# Claude Code SDK 설정 디렉토리 격리.
# 미설정 시 프로젝트 안 .claude_config/ 로 자동 격리(권장) → 홈 ~/.claude.json 동시
# write 경합 방지(대화형 Claude Code 세션을 같은 머신에서 병행해도 충돌 차단).
# 첫 실행 시 홈 로그인을 자동 승계하므로 재로그인 불필요.
# 격리를 끄고 홈 config를 그대로 쓰려면: SCREENER_CLAUDE_CONFIG_DIR=off
# 다른 경로로 격리하려면 그 경로를 지정.
#SCREENER_CLAUDE_CONFIG_DIR=off
